{
  "name": "elysium-15d-memory-system",
  "private": true,
  "version": "5.1.1",
  "description": "ELYSIUM 智脑极乐境 — 15D多维情感记忆 + MoE人格融合 + 文本具身引擎",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "dev:all": "node -e \"const{spawn}=require('child_process');spawn('npx',['vite','--host'],{stdio:'inherit',shell:true});spawn('node',['server/index.js'],{stdio:'inherit',shell:true});\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.6",
    "d3": "^7.9.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "idb": "^8.0.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
